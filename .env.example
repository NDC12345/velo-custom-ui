# ─── VeLo Custom UI — Environment Template ──────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file with real secrets to version control.

NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ─── Database ────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=velo_custom
DB_USER=velo_admin
DB_PASSWORD=<GENERATE: openssl rand -base64 24>

# ─── JWT ─────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
JWT_SECRET=<GENERATE>
JWT_ACCESS_SECRET=<GENERATE>
JWT_REFRESH_SECRET=<GENERATE>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
VELO_CREDENTIALS_ENCRYPTION_KEY=<GENERATE>

# ─── Velociraptor API ────────────────────────────────────────
VELO_API_BASE_URL=https://your-velociraptor-server.example.com
VELO_API_TIMEOUT=30000
VELO_API_VERIFY_SSL=true
VELO_SKIP_AUTH_CHECK=false

# ─── Google AI Studio (optional) ────────────────────────────
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_MAX=20

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── Security ───────────────────────────────────────────────
BCRYPT_ROUNDS=12
COOKIE_SECRET=<GENERATE: openssl rand -base64 24>

# ─── Velociraptor Org (leave blank for default) ─────────────
VELO_ORG_ID=
