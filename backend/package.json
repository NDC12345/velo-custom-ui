{
  "name": "velo-custom-ui-backend",
  "version": "1.0.0",
  "description": "Secure backend proxy for Velociraptor API with encrypted credential management",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:api": "node test-api.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js"
  },
  "keywords": [
    "velociraptor",
    "security",
    "proxy",
    "authentication",
    "encryption"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "https-proxy-agent": "^7.0.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "maxmind": "^4.3.21",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "pg-format": "^1.0.4",
    "redis": "^4.6.14",
    "winston": "^3.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "colors": "^1.4.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nock": "^13.5.6",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/helpers/setup.js"
    ],
    "forceExit": true,
    "testTimeout": 15000,
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 30,
        "lines": 40,
        "statements": 40
      }
    }
  }
}
