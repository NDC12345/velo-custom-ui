# ──────────────────────────────────────────────────────────────────────────────
# VeLo Custom UI — Backend Environment Configuration
# Copy this file to .env and fill in the values before running the stack.
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=velo_custom
DB_USER=velo_admin
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=CHANGE_ME
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME_different_from_above
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption (for stored Velociraptor credentials) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VELO_CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECRET=CHANGE_ME

# ── Velociraptor API ──────────────────────────────────────────────────────────
# The base URL of your Velociraptor server's REST/gRPC-gateway endpoint.
# For local servers: https://localhost:8889
# For ngrok tunnels: https://<your-subdomain>.ngrok-free.app
VELO_API_BASE_URL=https://your-velociraptor-server:8889
VELO_API_VERIFY_SSL=true
VELO_API_TIMEOUT=30000
VELO_SKIP_AUTH_CHECK=false

# Org ID for multi-tenant Velociraptor deployments (leave blank for default org)
VELO_ORG_ID=

# ── Velociraptor Service Account (used by the WebSocket gateway) ──────────────
# Create a dedicated read-only service account in Velociraptor for this purpose.
# See README.md > "Velociraptor API Setup" for required permission roles.
VELO_SERVICE_USERNAME=svc-velo-ui
VELO_SERVICE_PASSWORD=CHANGE_ME_service_password

# ── Velociraptor Admin Account (used ONLY by the seed script) ─────────────────
# Only needed when running: node database/seeds/01-admin-user.js
VELO_ADMIN_USERNAME=admin
VELO_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── Google AI Studio (AI assistant feature) ───────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
# Leave blank to disable the AI assistant.
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
CORS_ORIGIN=http://localhost:3000,https://your-domain.com
CORS_CREDENTIALS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_MAX=20

# ── GeoIP ─────────────────────────────────────────────────────────────────────
# Optional: path to MaxMind GeoLite2-City.mmdb for offline lookups.
# If absent, the system falls back to ip-api.com (free, 45 req/min limit).
# Download from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
MMDB_PATH=/geoip/GeoLite2-City.mmdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_GEO_TTL_DAYS=7

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_MS=30000
WS_DIFF_INTERVAL_MS=2000
WS_POLL_INTERVAL_MS=10000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Ports (override the defaults exposed by docker-compose) ───────────────────
FRONTEND_PORT=3000
BACKEND_PORT=5000
